{
  "name": "mobile-context-trimmer",
  "version": "0.1.0",
  "description": "CLI and library for building LLM context bundles for native iOS and Android projects",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "mobile-context-trimmer": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "ios",
    "android",
    "mobile",
    "swift",
    "kotlin",
    "llm",
    "context",
    "cli",
    "typescript",
    "codebase",
    "xcode",
    "gradle"
  ],
  "author": "isonka",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/isonka/mobile-context-trimmer.git"
  },
  "bugs": {
    "url": "https://github.com/isonka/mobile-context-trimmer/issues"
  },
  "homepage": "https://github.com/isonka/mobile-context-trimmer#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "dependencies": {
    "ignore": "^7.0.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@emnapi/core": "1.9.2",
    "@emnapi/runtime": "1.9.2",
    "@types/node": "^25.5.2",
    "@types/yargs": "^17.0.35",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
